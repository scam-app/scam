# Required
OPENAI_API_KEY=sk-your-key-here

# Optional — upgrade the model used by specialists + assistant.
# Defaults to gpt-4o-mini (still works via the API). Set to a current
# model your account supports, e.g. a GPT-5 family model, after confirming
# the exact API model string in your OpenAI dashboard.
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_CHAT_MODEL=gpt-4o-mini
